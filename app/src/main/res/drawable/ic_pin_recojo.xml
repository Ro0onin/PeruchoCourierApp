<?xml version="1.0" encoding="utf-8"?>
<!--
    ic_pin_recojo.xml
    Colocar en: res/drawable/ic_pin_recojo.xml
    Uso:  bitmapDescriptorFromDrawableSafe(context, R.drawable.ic_pin_recojo, 120, 120)
    ViewBox: 56 × 70 px  →  escala bien a 120×120 dp en el mapa
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="56dp"
    android:height="70dp"
    android:viewportWidth="56"
    android:viewportHeight="70">

    <!-- ── Sombra difusa debajo del pin ── -->
    <path
        android:fillColor="#3322C55E"
        android:pathData="M28,67 Q16,55 10,42 Q6,33 6,26 Q6,12 16,6 Q22,2 28,2 Q34,2 40,6 Q50,12 50,26 Q50,33 46,42 Q40,55 28,67Z" />

    <!-- ── Cuerpo del pin con degradado simulado ── -->
    <!-- capa base (color más oscuro) -->
    <path
        android:fillColor="#16A34A"
        android:pathData="M28,4 C16.4,4 7,13.4 7,25 C7,41 28,68 28,68 C28,68 49,41 49,25 C49,13.4 39.6,4 28,4Z" />
    <!-- capa superior más clara para efecto de luz -->
    <path
        android:fillColor="#22C55E"
        android:pathData="M28,4 C16.4,4 7,13.4 7,25 C7,36 16,46 24,56 C26,59 28,62 28,68 C28,68 49,41 49,25 C49,13.4 39.6,4 28,4Z"
        android:fillAlpha="0.55"/>

    <!-- ── Círculo blanco interior ── -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M28,13 A12,12 0 1,1 28,37 A12,12 0 1,1 28,13Z" />

    <!-- ── Caja con lazo ── -->

    <!-- relleno suave de la caja -->
    <path
        android:fillColor="#22C55E"
        android:fillAlpha="0.15"
        android:pathData="M18,19 L38,19 L38,33 L18,33Z" />

    <!-- borde de la caja -->
    <path
        android:strokeColor="#22C55E"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M18,19 L38,19 L38,33 L18,33 Z" />

    <!-- línea horizontal de la caja -->
    <path
        android:strokeColor="#22C55E"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M18,24 L38,24" />

    <!-- línea vertical de la caja -->
    <path
        android:strokeColor="#22C55E"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M28,19 L28,33" />

    <!-- lazo arriba de la caja -->
    <path
        android:strokeColor="#22C55E"
        android:strokeWidth="1.6"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M24,19 Q28,15 32,19" />

</vector>
